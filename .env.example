# TradingBot v3.2 — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to GitHub!

# ── Core ──────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── KotakNeo (READ-ONLY — bot will NEVER trade) ──
# Get API key from: https://neo.kotaksecurities.com -> Settings -> API
# REGENERATE your key first — the old one may be compromised
KOTAK_API_KEY=your_kotak_api_key_here

# Access token — generate fresh daily from KotakNeo dashboard
# POST https://napi.kotaksecurities.com/oauth2/1.0/token
KOTAK_ACCESS_TOKEN=your_kotak_access_token_here

# ── Twitter/X (OPTIONAL — bot works without this) ──
# Only needed if Nitter RSS is down. Get from developer.twitter.com
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here
